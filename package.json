{
  "name": "secure-notes-cicd",
  "version": "1.0.0",
  "description": "A beginner-intermediate CI/CD pipeline lab for a secure notes API",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --runInBand",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "audit": "npm audit --audit-level=high",
    "check": "npm run lint && npm test"
  },
  "keywords": [
    "ci-cd",
    "devsecops",
    "nodejs",
    "express",
    "security"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.11.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "globals": "^17.6.0",
    "jest": "^30.4.2",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  }
}
